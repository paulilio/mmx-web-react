# URL do banco — aponta para o servico postgres do compose
DATABASE_URL=postgresql://mmx:mmx_password@postgres:5432/mmx?schema=public

# Modo de API
NEXT_PUBLIC_USE_API=true
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_API_MIGRATION_DOMAINS=

# Ambiente
NODE_ENV=production
MMX_APP_ENV=production

# CORS — lista CSV de origens permitidas
CORS_ORIGINS_DEV=
CORS_ORIGINS_STAGING=
CORS_ORIGINS_PROD=https://seu-dominio.com

# OAuth Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://seu-dominio.com/api/auth/oauth/google/callback

# OAuth Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://seu-dominio.com/api/auth/oauth/microsoft/callback
MICROSOFT_TENANT_ID=common
