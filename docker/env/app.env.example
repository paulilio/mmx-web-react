# URL do banco — aponta para o servico postgres do compose
DATABASE_URL=postgresql://mmx:mmx_password@postgres:5432/mmx?schema=public

# Modo de API
NEXT_PUBLIC_USE_API=true
NEXT_PUBLIC_API_BASE=

# Ambiente
NODE_ENV=development
MMX_APP_ENV=development

# CORS — lista CSV de origens permitidas
CORS_ORIGINS_DEV=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS_STAGING=
CORS_ORIGINS_PROD=

# OAuth Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

# OAuth Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/oauth/microsoft/callback
MICROSOFT_TENANT_ID=common
