{
  "name": "mmx-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @mmx/web build",
    "build:api": "pnpm --filter @mmx/api build",
    "build:web": "pnpm --filter @mmx/web build",
    "clean": "pnpm --filter @mmx/web clean",
    "dev": "pnpm --filter @mmx/web dev",
    "dev:api": "pnpm --filter @mmx/api start:dev",
    "dev:web": "pnpm --filter @mmx/web dev",
    "docker:dev:build:backend": "node docker/scripts/run-compose.mjs dev --profile split build backend",
    "docker:dev:down": "node docker/scripts/run-compose.mjs dev down",
    "docker:dev:logs": "node docker/scripts/run-compose.mjs dev logs -f app",
    "docker:dev:logs:backend": "node docker/scripts/run-compose.mjs dev logs -f backend",
    "docker:dev:logs:monitor": "node docker/scripts/run-compose.mjs dev logs -f monitor",
    "docker:dev:ps": "node docker/scripts/run-compose.mjs dev ps",
    "docker:dev:rebuild": "pnpm docker:dev:down && pnpm docker:dev:up",
    "docker:dev:up": "node docker/scripts/run-compose.mjs dev up --build -d",
    "docker:dev:up:split": "node docker/scripts/run-compose.mjs dev --profile split up -d",
    "docker:dev:up:split:build": "node docker/scripts/run-compose.mjs dev --profile split up --build -d",
    "docker:prod:build:backend": "node docker/scripts/run-compose.mjs prod --profile split build backend",
    "docker:prod:down": "node docker/scripts/run-compose.mjs prod down",
    "docker:prod:logs": "node docker/scripts/run-compose.mjs prod logs -f app",
    "docker:prod:logs:backend": "node docker/scripts/run-compose.mjs prod logs -f backend",
    "docker:prod:logs:monitor": "node docker/scripts/run-compose.mjs prod logs -f monitor",
    "docker:prod:ps": "node docker/scripts/run-compose.mjs prod ps",
    "docker:prod:rebuild": "pnpm docker:prod:down && pnpm docker:prod:up",
    "docker:prod:up": "node docker/scripts/run-compose.mjs prod up --build -d",
    "docker:prod:up:split": "node docker/scripts/run-compose.mjs prod --profile split up -d",
    "docker:prod:up:split:build": "node docker/scripts/run-compose.mjs prod --profile split up --build -d",
    "lint": "pnpm --filter @mmx/web lint",
    "lint:fix": "pnpm --filter @mmx/web lint:fix",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema apps/api/prisma/schema.prisma",
    "start": "pnpm --filter @mmx/web start",
    "test:integration": "pnpm --filter @mmx/api test",
    "test:integration:watch": "pnpm --filter @mmx/api test -- --watch",
    "test:unit": "pnpm --filter @mmx/web test:unit",
    "test:unit:watch": "pnpm --filter @mmx/web test:unit:watch",
    "type-check": "pnpm --filter @mmx/web type-check",
    "validate:env": "node scripts/validate-env.mjs"
  },
