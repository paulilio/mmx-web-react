{
  "name": "mmx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mmx/web dev",
    "build": "pnpm --filter @mmx/web build",
    "dev:api": "pnpm --filter @mmx/api dev",
    "build:api": "pnpm --filter @mmx/api build",
    "docker:dev:build:backend": "node tools/docker/scripts/run-compose.mjs dev --profile split build backend",
    "docker:dev:down": "node tools/docker/scripts/run-compose.mjs dev down",
    "docker:dev:logs": "node tools/docker/scripts/run-compose.mjs dev logs -f app",
    "docker:dev:logs:backend": "node tools/docker/scripts/run-compose.mjs dev logs -f backend",
    "docker:dev:logs:monitor": "node tools/docker/scripts/run-compose.mjs dev logs -f monitor",
    "docker:dev:ps": "node tools/docker/scripts/run-compose.mjs dev ps",
    "docker:dev:rebuild": "pnpm docker:dev:down && pnpm docker:dev:up",
    "docker:dev:up": "node tools/docker/scripts/run-compose.mjs dev up --build -d",
    "docker:dev:up:split": "node tools/docker/scripts/run-compose.mjs dev --profile split up -d",
    "docker:dev:up:split:build": "node tools/docker/scripts/run-compose.mjs dev --profile split up --build -d",
    "docker:prod:build:backend": "node tools/docker/scripts/run-compose.mjs prod --profile split build backend",
    "docker:prod:down": "node tools/docker/scripts/run-compose.mjs prod down",
    "docker:prod:logs": "node tools/docker/scripts/run-compose.mjs prod logs -f app",
    "docker:prod:logs:backend": "node tools/docker/scripts/run-compose.mjs prod logs -f backend",
    "docker:prod:logs:monitor": "node tools/docker/scripts/run-compose.mjs prod logs -f monitor",
    "docker:prod:ps": "node tools/docker/scripts/run-compose.mjs prod ps",
    "docker:prod:rebuild": "pnpm docker:prod:down && pnpm docker:prod:up",
    "docker:prod:up": "node tools/docker/scripts/run-compose.mjs prod up --build -d",
    "docker:prod:up:split": "node tools/docker/scripts/run-compose.mjs prod --profile split up -d",
    "docker:prod:up:split:build": "node tools/docker/scripts/run-compose.mjs prod --profile split up --build -d",
    "prisma:generate": "prisma generate --schema packages/api/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema packages/api/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema packages/api/prisma/schema.prisma",
    "test:integration": "pnpm --filter @mmx/api test",
    "test:integration:watch": "pnpm --filter @mmx/api test -- --watch",
    "test:unit": "pnpm --filter @mmx/web test:unit",
    "validate:env": "node scripts/validate-env.mjs"
  },
  "devDependencies": {
    "prisma": "^6.19.2",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild", "@nestjs/core", "@parcel/watcher"]
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.1.1",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.454.0",
    "react": "^19.2.4",
    "sonner": "^1.7.4"
  }
}
