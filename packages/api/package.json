{
  "name": "@mmx/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --package=typescript@5.9.3 dlx tsc -p tsconfig.json && pnpm --package=tsc-alias@1.8.10 dlx tsc-alias -p tsconfig.json",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint src --ext .ts",
    "test": "pnpm --package=vitest@4.0.18 dlx vitest run",
    "test:unit": "pnpm --package=vitest@4.0.18 dlx vitest run",
    "db:migrate": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.0.0",
    "ts-jest": "^29.2.5"
  }
}
