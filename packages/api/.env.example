DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mmx?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/mmx?schema=public"
MMX_APP_ENV=development
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
CORS_ORIGINS_DEV=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS_STAGING=
CORS_ORIGINS_PROD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=common

# ---- Open Finance (Belvo) ----
# Helper de encryption AES-256-GCM (gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
MMX_ENCRYPTION_KEY=

# Dashboard Belvo → Settings → API Keys
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=
BELVO_ENV=sandbox
BELVO_WEBHOOK_SECRET=

# Auto-reconciliação de transações importadas (off por default)
MMX_OPEN_FINANCE_AUTO_RECONCILE=false
