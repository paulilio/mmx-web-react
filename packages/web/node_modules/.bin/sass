#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/d/Pauli/Projects/MMX/mmx-web-react/node_modules/.pnpm/sass@1.98.0/node_modules/sass/node_modules:/proc/cygdrive/d/Pauli/Projects/MMX/mmx-web-react/node_modules/.pnpm/sass@1.98.0/node_modules:/proc/cygdrive/d/Pauli/Projects/MMX/mmx-web-react/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/d/Pauli/Projects/MMX/mmx-web-react/node_modules/.pnpm/sass@1.98.0/node_modules/sass/node_modules:/proc/cygdrive/d/Pauli/Projects/MMX/mmx-web-react/node_modules/.pnpm/sass@1.98.0/node_modules:/proc/cygdrive/d/Pauli/Projects/MMX/mmx-web-react/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../node_modules/.pnpm/sass@1.98.0/node_modules/sass/sass.js" "$@"
else
  exec node  "$basedir/../../../../node_modules/.pnpm/sass@1.98.0/node_modules/sass/sass.js" "$@"
fi
