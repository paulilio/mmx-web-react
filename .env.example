# Castler ops tooling secrets (raiz MMX)
# Copiar para .env e preencher valores reais.
# .env é gitignored; .env.example é versionado.

# ---- ImprovMX (email forwarding castlerdigital.com.br) ----
# https://app.improvmx.com/api
IMPROVMX_API_KEY=

# ---- Belvo (Open Finance) ----
# https://dashboard.belvo.com → Settings → API Keys
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=
BELVO_ENV=sandbox

# ---- MMX Alpha deploy (Azure Container Apps) ----
# Ver: .aiws/docs/sops/sop-deploy-azure-container-apps.md
GHCR_USERNAME=
GHCR_PAT=                                            # GitHub PAT · scope: read:packages
MMX_IMAGE=ghcr.io/<user>/mmx-api:alpha-v1            # Publicada por .github/workflows/api-build.yml
DATABASE_URL=                                        # Neon pooled connection
DIRECT_URL=                                          # Neon direct connection (migrações)
JWT_ACCESS_SECRET=                                   # 48 bytes base64 · gerar com RNG criptográfico
JWT_REFRESH_SECRET=                                  # 48 bytes base64 · gerar com RNG criptográfico
MMX_APP_ENV=production
CORS_ORIGINS_PROD=https://mmx-platform.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=common
