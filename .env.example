# Castler ops tooling secrets (raiz MMX)
# Copiar para .env e preencher valores reais.
# .env é gitignored; .env.example é versionado.

# ---- ImprovMX (email forwarding castlerdigital.com.br) ----
# https://app.improvmx.com/api
IMPROVMX_API_KEY=

# ---- Cloudflare (DNS management para moedamix.com.br) ----
# https://dash.cloudflare.com → My Profile → API Tokens (token escopado a uma zona)
# Account ID visível no painel do dashboard, sidebar direita
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=moedamix.com.br

# ---- Belvo (Open Finance) ----
# https://dashboard.belvo.com → Settings → API Keys
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=
BELVO_ENV=sandbox

# ---- MMX Alpha deploy (Azure Container Apps) ----
# Ver: .aiws/docs/sops/sop-deploy-azure-container-apps.md
GHCR_USERNAME=
GHCR_PAT=                                            # GitHub PAT · scope: read:packages
MMX_IMAGE=ghcr.io/<user>/mmx-api:alpha-v1            # Publicada por .github/workflows/api-build.yml
DATABASE_URL=                                        # Neon pooled connection
DIRECT_URL=                                          # Neon direct connection (migrações)
JWT_ACCESS_SECRET=                                   # 48 bytes base64 · gerar com RNG criptográfico
JWT_REFRESH_SECRET=                                  # 48 bytes base64 · gerar com RNG criptográfico
MMX_APP_ENV=production
CORS_ORIGINS_PROD=https://mmx-platform.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=common

# ---- Auth: Frontend redirect (OAuth + magic link) ----
FRONTEND_URL=https://mmx-platform.vercel.app
API_BASE_URL=https://ca-mmx-api-alpha.happymushroom-aaae7c9b.eastus.azurecontainerapps.io

# ---- Auth: SMTP transacional (verify email + reset password) ----
# Opções para Alpha (em ordem de simplicidade):
# A) Gmail SMTP (App Password):  smtp.gmail.com / 587 / paulilio.ferreira@gmail.com / app-password
# B) ImprovMX SMTP (Premium):    smtp.improvmx.com / 587 / contato@castlerdigital.com.br / improvmx-smtp-pass
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_ADDRESS=no-reply@castlerdigital.com.br
EMAIL_FROM_NAME=MoedaMix
