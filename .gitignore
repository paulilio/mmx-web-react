# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/packages/*/node_modules
/tools/*/node_modules

# workspace build artifacts
/packages/*/dist

# workspace lockfiles (root lockfile is canonical)
/packages/*/pnpm-lock.yaml

# monorepo/cache tools
.turbo/
.nx/
.pnpm-store/

# next.js
/.next/
/packages/web/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# lint/test caches
.eslintcache
coverage/

# env files (per-package, not tracked — only .env.example is versioned)
packages/api/.env*
!packages/api/.env.example
packages/web/.env*
!packages/web/.env.example

# docker env files (versionar apenas templates .example)
tools/docker/env/*.env
!tools/docker/env/*.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pasta privada temp do dev
.dev-workspace/*
.ws-dev/

# runtime outputs (front/api/monitor)
runtime/**
!runtime/**/
!runtime/**/.gitkeep
packages/*/runtime/**
!packages/*/runtime/**/
!packages/*/runtime/**/.gitkeep
