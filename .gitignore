# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# docker env files (versionar apenas templates .example)
docker/env/*.env
!docker/env/*.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pasta privada temp do dev
.dev-workspace/*

# monitor - artifacts
monitor/artifacts/screenshots/*.png
monitor/artifacts/html/*.html
monitor/artifacts/network/*

# monitor - logs
monitor/logs/debug/*.log
monitor/logs/sessions/

# monitor - reports
monitor/reports/incidentes/*.md
monitor/reports/analysis/