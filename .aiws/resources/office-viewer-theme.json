{
  "_comment": "Office Viewer Theme Customization. null = inherit from theme (recommended for Auto mode). Run 'Apply Office Viewer Theme' task after changes.",

  "headings": {
    "h1": { "margin-top": "12px", "margin-bottom": "11px", "font-size": "1.75em", "font-color": "#ff7362", "font-weight": "480" },
    "h2": { "margin-top": "12px", "margin-bottom": "11px", "font-size": "1.55em", "font-color": "#1bbbfe", "font-weight": "480" },
    "h3": { "margin-top": "12px", "margin-bottom": "11px", "font-size": "1.38em", "font-color": "#a25aff", "font-weight": "480" },
    "h4": { "margin-top": "12px", "margin-bottom": "11px", "font-size": "1.25em", "font-color": "#0dcf85", "font-weight": "480" },
    "h5": { "margin-top": "12px", "margin-bottom": "11px", "font-size": "1.13em", "font-color": null, "font-weight": "480" },
    "h6": { "margin-top": "12px", "margin-bottom": "11px", "font-size": "1em", "font-color": null, "font-weight": "480" }
  },

  "inlineCode": {
    "text-color": null,
    "background-color": null,
    "margin-left": "0",
    "margin-right": "0",
    "padding-left": "0.4em",
    "padding-right": "0.4em"
  },

  "tables": {
    "margin-top": "0",
    "margin-bottom": "16px",
    "cell-padding-top": "6px",
    "cell-padding-bottom": "6px",
    "cell-padding-left": "13px",
    "cell-padding-right": "13px",
    "border-color": "#5DBFC3",
    "border-width": "1px"
  },

  "text": {
    "line-height": "1.6",
    "paragraph-spacing": "8px"
  },

  "lists": {
    "bullet-color": "#19bcfe",
    "numeric-color": "#19bcfe",
    "item-spacing": "0.20em",
    "list-margin-bottom": "12px",
    "padding-left": "2em"
  },

  "bold": {
    "font-weight": "700",
    "font-color": "#5DBFC3"
  },

  "italic": {
    "font-weight": null,
    "font-color": "#D2D457"
  },

  "boldItalic": {
    "font-weight": "700",
    "font-color": "#D26363"
  },

  "codeBlocks": {
    "margin-top": "1em",
    "margin-bottom": "1em"
  },

  "blockquote": {
    "bar-color": null,
    "bar-width": "0.25em",
    "text-color": null,
    "background-color": "#434343",
    "border-color": null,
    "border-width": null,
    "border-radius": null,
    "margin-bottom": "3px",
    "padding-left": "1em",
    "padding-top": "0.5em",
    "padding-bottom": "0.1em"
  },

  "outline": {
    "font-size": "0.8em",
    "font-color": null,
    "hover-color": null,
    "match-heading-colors": true
  },

  "headingLabels": {
    "hide": true
  },

  "collapse": {
    "enabled": true,
    "triangle-color": "#676a6d"
  },

  "horizontalRule": {
    "color": null,
    "margin-top": "12px",
    "margin-bottom": "12px",
    "height": "2px"
  }
}